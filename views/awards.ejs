<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Awards Management</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/careers.css">
    <link rel="stylesheet" href="/styles/members-admin.css">
    <style>
        /* ── Stats strip ─────────────────────────────── */
        .awards-stats {
            display: flex;
            gap: 1rem;
            margin-bottom: 28px;
        }
        .awards-stat {
            flex: 1;
            background: #fff;
            border: 1px solid #eef0fb;
            border-radius: 10px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .awards-stat__icon {
            width: 44px; height: 44px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; flex-shrink: 0;
        }
        .aw-icon--blue  { background: #e8eaf9; color: #27247B; }
        .aw-icon--gold  { background: #fff3cd; color: #b7791f; }
        .aw-icon--green { background: #d8eede; color: #276749; }
        .awards-stat__num { font-size: 1.6rem; font-weight: 700; color: #222; line-height: 1; }
        .awards-stat__lbl { font-size: .8rem; color: #888; margin-top: 3px; }

        /* ── Award cards ─────────────────────────────── */
        .awards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px;
        }
        .award-admin-card {
            background: #fff;
            border: 1px solid #eef0fb;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: box-shadow .2s;
        }
        .award-admin-card:hover { box-shadow: 0 6px 20px rgba(39,36,123,.08); }

        .award-admin-card__img {
            width: 100%; height: 170px; object-fit: cover;
        }
        .award-admin-card__img--placeholder {
            height: 170px;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #f8f9fc, #eef0fb);
            color: #c5c8e8; font-size: 2.8rem;
        }
        .award-admin-card__body {
            padding: 18px 20px; flex: 1; display: flex; flex-direction: column;
        }
        .award-admin-card__title {
            font-size: 15px; font-weight: 700; color: #222; margin-bottom: 8px;
        }
        .award-admin-card__desc {
            font-size: 13px; color: #777; line-height: 1.55;
            margin-bottom: 14px; flex: 1;
            display: -webkit-box; -webkit-line-clamp: 3;
            -webkit-box-orient: vertical; overflow: hidden;
        }
        .award-admin-card__meta {
            display: flex; gap: 14px; font-size: 12px; color: #888;
            margin-bottom: 14px; flex-wrap: wrap;
        }
        .award-admin-card__meta span { display: flex; align-items: center; gap: 4px; }

        .chip {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 4px 10px; border-radius: 20px;
            font-size: .78rem; font-weight: 600;
        }
        .chip--regs   { background: #e8eaf9; color: #27247B; }
        .chip--win    { background: #fff3cd; color: #b7791f; }
        .chip--open   { background: #d8eede; color: #276749; }
        .chip--closed { background: #f0f1f9; color: #888; }

        .award-admin-card__chips { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
        .award-admin-card__actions { display: flex; gap: 8px; }

        .btn-card-regs {
            flex: 1; padding: 9px;
            background: #27247B; color: #fff;
            border: none; border-radius: 7px;
            font-size: 13px; font-weight: 600; cursor: pointer;
            text-decoration: none;
            display: flex; align-items: center; justify-content: center; gap: 6px;
        }
        .btn-card-regs:hover { background: #1a1860; color: #fff; }
        .btn-card-edit {
            padding: 9px 14px;
            background: #fff; color: #27247B;
            border: 1px solid #27247B; border-radius: 7px;
            font-size: 13px; cursor: pointer;
        }
        .btn-card-edit:hover { background: #27247B; color: #fff; }
        .btn-card-del {
            padding: 9px 14px;
            background: #fff; color: #e53e3e;
            border: 1px solid #fca5a5; border-radius: 7px;
            font-size: 13px; cursor: pointer;
        }
        .btn-card-del:hover { background: #fde8e8; }

        .no-awards { text-align: center; padding: 48px; color: #bbb; }
        .no-awards i { font-size: 2.5rem; margin-bottom: 12px; display: block; }

        /* ── Modal ───────────────────────────────────── */
        .award-modal-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.45);
            align-items: center; justify-content: center; z-index: 1000;
        }
        .award-modal-overlay.open { display: flex; }
        .award-modal {
            background: #fff; border-radius: 12px;
            padding: 28px 32px; width: 540px;
            max-width: 95vw; max-height: 90vh; overflow-y: auto;
        }
        .award-modal h3 { font-size: 17px; font-weight: 700; color: #222; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
        .award-modal label { display: block; font-size: 12px; font-weight: 600; color: #555; margin-bottom: 5px; margin-top: 14px; }
        .award-modal input,
        .award-modal textarea { width: 100%; padding: 9px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; font-family: inherit; box-sizing: border-box; }
        .award-modal textarea { resize: vertical; }
        .award-modal-row { display: flex; gap: 14px; }
        .award-modal-row > div { flex: 1; }
        .award-modal-footer { display: flex; gap: 10px; margin-top: 22px; justify-content: flex-end; }
        .img-preview-wrap { display: flex; align-items: center; gap: 12px; margin-top: 8px; }
        .img-preview-wrap img { width: 72px; height: 72px; object-fit: cover; border-radius: 8px; border: 1px solid #eee; }
        .btn-upload-label {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 14px; background: #f8f9fc;
            border: 1px dashed #ccc; border-radius: 6px;
            font-size: 13px; color: #555; cursor: pointer;
        }
        .btn-upload-label:hover { border-color: #27247B; color: #27247B; }
    </style>
</head>
<body>
    <%- include('../partials/sidebar') %>
    <%- include('../partials/header') %>

    <main class="content">

        <!-- Page header -->
        <div class="panel-header" style="margin-bottom:24px;">
            <div>
                <h2 style="font-size:1.3rem;font-weight:700;color:#222;margin:0 0 4px;">
                    <i class="fas fa-trophy" style="color:#b7791f;margin-right:8px;"></i>Awards Management
                </h2>
                <p style="font-size:13px;color:#888;margin:0;">Manage ARDE competitions and award registrations</p>
            </div>
            <button class="btn-add" onclick="openCreate()">
                <i class="fas fa-plus"></i> New Award
            </button>
        </div>

        <!-- Flash messages -->
        <% if (error) { %>
        <div class="alert-error" style="margin-bottom:16px;"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>
        <% if (notice) { %>
        <div class="alert-notice" style="margin-bottom:16px;"><i class="fas fa-check-circle"></i> <%= notice %></div>
        <% } %>

        <%
        const now = new Date();
        const openCount    = awards.filter(a => new Date(a.deadline) >= now).length;
        const totalRegs    = Object.values(regCounts).reduce((s,n) => s + n, 0);
        const totalWinners = Object.values(winnerCounts).reduce((s,n) => s + n, 0);
        %>

        <div class="main-layout">

            <!-- ── Left sidebar ───────────────────────── -->
            <aside class="sidebar-info">

                <!-- Stats -->
                <div class="stats-row-card">
                    <div class="stats-mini">
                        <div class="stats-num"><%= awards.length %></div>
                        <div class="stats-label">Total</div>
                    </div>
                    <div class="stats-mini">
                        <div class="stats-num" style="color:#276749;"><%= openCount %></div>
                        <div class="stats-label">Open</div>
                    </div>
                    <div class="stats-mini">
                        <div class="stats-num" style="color:#b7791f;"><%= totalRegs %></div>
                        <div class="stats-label">Registrants</div>
                    </div>
                </div>

                <!-- Quick award list -->
                <div class="apps-card">
                    <h4><i class="fas fa-trophy" style="color:#b7791f;margin-right:6px;"></i> Awards</h4>
                    <% awards.forEach(a => {
                        const aOpen = new Date(a.deadline) >= now;
                        const aRegs = regCounts[a.id] || 0;
                    %>
                    <a href="/awards/registrations/<%= a.id %>" class="app-row">
                        <span class="app-count <%= aRegs === 0 ? 'zero' : '' %>">
                            <%= aRegs %>
                        </span>
                        <span class="app-label" style="flex:1;"><%= a.title %></span>
                        <span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;margin-right:4px;
                              background:<%= aOpen ? '#d8eede' : '#f0f1f9' %>;
                              color:<%= aOpen ? '#276749' : '#999' %>;">
                            <%= aOpen ? 'Open' : 'Closed' %>
                        </span>
                        <i class="fas fa-chevron-right app-arrow"></i>
                    </a>
                    <% }) %>
                    <% if (awards.length === 0) { %>
                    <p style="font-size:13px;color:#aaa;padding:12px 0;text-align:center;">No awards yet</p>
                    <% } %>
                </div>

            </aside>

            <!-- ── Main content ───────────────────────── -->
            <section style="flex:1;min-width:0;">

                <!-- Filter bar -->
                <div class="filter-bar" style="margin-bottom:20px;">
                    <input type="text" id="searchInput" class="filter-select"
                           placeholder="Search awards…" oninput="applyFilters()"
                           style="flex:1;max-width:260px;">
                    <select class="filter-select" id="statusFilter" onchange="applyFilters()">
                        <option value="all">All statuses</option>
                        <option value="open">Open</option>
                        <option value="closed">Closed</option>
                    </select>
                </div>

                <!-- Awards grid -->
                <div class="awards-grid" id="awardsGrid">
                    <% awards.forEach(award => {
                        const isOpen = new Date(award.deadline) >= now;
                        const regs   = regCounts[award.id]    || 0;
                        const wins   = winnerCounts[award.id] || 0;
                    %>
                    <div class="award-admin-card"
                         data-status="<%= isOpen ? 'open' : 'closed' %>"
                         data-title="<%= award.title.toLowerCase() %>">

                        <% if (award.image_path) { %>
                        <img class="award-admin-card__img" src="<%= award.image_path %>" alt="<%= award.title %>">
                        <% } else { %>
                        <div class="award-admin-card__img--placeholder"><i class="fas fa-trophy"></i></div>
                        <% } %>

                        <div class="award-admin-card__body">
                            <div class="award-admin-card__title"><%= award.title %></div>

                            <% if (award.description) { %>
                            <p class="award-admin-card__desc"><%= award.description %></p>
                            <% } %>

                            <div class="award-admin-card__meta">
                                <span><i class="fas fa-calendar-alt"></i>
                                    <%= new Date(award.deadline).toLocaleDateString('en-SG',{day:'numeric',month:'short',year:'numeric'}) %>
                                </span>
                                <span><i class="fas fa-star"></i> Max <%= award.max_winners %> winner<%= award.max_winners !== 1 ? 's' : '' %></span>
                            </div>

                            <div class="award-admin-card__chips">
                                <span class="chip chip--regs"><i class="fas fa-users"></i> <%= regs %> registrant<%= regs !== 1 ? 's' : '' %></span>
                                <span class="chip chip--win"><i class="fas fa-trophy"></i> <%= wins %> winner<%= wins !== 1 ? 's' : '' %></span>
                                <span class="chip <%= isOpen ? 'chip--open' : 'chip--closed' %>">
                                    <i class="fas fa-circle" style="font-size:.45rem;"></i> <%= isOpen ? 'Open' : 'Closed' %>
                                </span>
                            </div>

                            <div class="award-admin-card__actions">
                                <a href="/awards/registrations/<%= award.id %>" class="btn-card-regs">
                                    <i class="fas fa-users"></i> Registrations
                                </a>
                                <button class="btn-card-edit"
                                    data-id="<%= award.id %>"
                                    data-title="<%= (award.title||'').replace(/"/g,'&quot;') %>"
                                    data-deadline="<%= new Date(award.deadline).toISOString().split('T')[0] %>"
                                    data-max="<%= award.max_winners %>"
                                    data-desc="<%= (award.description||'').replace(/"/g,'&quot;') %>"
                                    data-img="<%= award.image_path || '' %>"
                                    onclick="openEditFromBtn(this)"><i class="fas fa-pen"></i></button>
                                <form action="/awards/delete/<%= award.id %>" method="POST"
                                      style="display:inline"
                                      onsubmit="return confirm('Remove this award?')">
                                    <button class="btn-card-del" type="submit"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <div id="emptyState" class="no-awards" style="display:none;">
                    <i class="fas fa-trophy"></i>
                    <p>No awards found.</p>
                </div>

            </section>

        </div><!-- /.main-layout -->

    </main>

    <!-- ===== CREATE MODAL ===== -->
    <div class="award-modal-overlay" id="createModal">
        <div class="award-modal">
            <h3><i class="fas fa-plus" style="color:#27247B;"></i> Create New Award</h3>
            <form action="/awards/create" method="POST" enctype="multipart/form-data">
                <label>Title</label>
                <input type="text" name="title" placeholder="e.g. Singapore Best Receptionist Competition 2026" required>

                <div class="award-modal-row">
                    <div>
                        <label>Deadline</label>
                        <input type="date" name="deadline" required>
                    </div>
                    <div>
                        <label>Max Winners</label>
                        <input type="number" name="max_winners" value="1" min="1" required>
                    </div>
                </div>

                <label>Description</label>
                <textarea name="description" rows="4" placeholder="Brief description of this award…"></textarea>

                <label>Image</label>
                <div class="img-preview-wrap">
                    <img id="create-preview" src="/images/placeholder.jpg" alt="Preview">
                    <label class="btn-upload-label">
                        <i class="fas fa-upload"></i> Upload Image
                        <input type="file" name="image" accept="image/*" hidden onchange="previewImage(this,'create-preview')">
                    </label>
                </div>

                <div class="award-modal-footer">
                    <button type="button" class="btn-app-delete" onclick="closeCreate()">Cancel</button>
                    <button type="submit" class="btn-add"><i class="fas fa-check"></i> Create Award</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ===== EDIT MODAL ===== -->
    <div class="award-modal-overlay" id="editModal">
        <div class="award-modal">
            <h3><i class="fas fa-pen" style="color:#27247B;"></i> Edit Award</h3>
            <form id="editForm" method="POST" enctype="multipart/form-data">
                <label>Title</label>
                <input type="text" name="title" id="edit-title" required>

                <div class="award-modal-row">
                    <div>
                        <label>Deadline</label>
                        <input type="date" name="deadline" id="edit-deadline" required>
                    </div>
                    <div>
                        <label>Max Winners</label>
                        <input type="number" name="max_winners" id="edit-max-winners" min="1" required>
                    </div>
                </div>

                <label>Description</label>
                <textarea name="description" id="edit-description" rows="4"></textarea>

                <label>Image</label>
                <div class="img-preview-wrap">
                    <img id="edit-preview" src="/images/placeholder.jpg" alt="Preview">
                    <label class="btn-upload-label">
                        <i class="fas fa-upload"></i> Replace Image
                        <input type="file" name="image" accept="image/*" hidden onchange="previewImage(this,'edit-preview')">
                    </label>
                </div>

                <div class="award-modal-footer">
                    <button type="button" class="btn-app-delete" onclick="closeEdit()">Cancel</button>
                    <button type="submit" class="btn-add"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function previewImage(input, id) {
            if (!input.files[0]) return;
            const r = new FileReader();
            r.onload = e => document.getElementById(id).src = e.target.result;
            r.readAsDataURL(input.files[0]);
        }

        function openCreate() {
            document.getElementById('createModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeCreate() {
            document.getElementById('createModal').classList.remove('open');
            document.body.style.overflow = '';
        }

        function openEditFromBtn(btn) {
            openEdit(
                btn.dataset.id,
                btn.dataset.title,
                btn.dataset.deadline,
                btn.dataset.max,
                btn.dataset.desc,
                btn.dataset.img
            );
        }

        function openEdit(id, title, deadline, maxWinners, description, imagePath) {
            document.getElementById('editForm').action = '/awards/update/' + id;
            document.getElementById('edit-title').value       = title;
            document.getElementById('edit-deadline').value    = deadline;
            document.getElementById('edit-max-winners').value = maxWinners;
            document.getElementById('edit-description').value = description;
            document.getElementById('edit-preview').src       = imagePath || '/images/placeholder.jpg';
            document.getElementById('editModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeEdit() {
            document.getElementById('editModal').classList.remove('open');
            document.body.style.overflow = '';
        }

        ['createModal','editModal'].forEach(id => {
            document.getElementById(id).addEventListener('click', function(e) {
                if (e.target === this) { this.classList.remove('open'); document.body.style.overflow = ''; }
            });
        });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeCreate(); closeEdit(); } });

        function applyFilters() {
            const q      = document.getElementById('searchInput').value.toLowerCase();
            const status = document.getElementById('statusFilter').value;
            let visible  = 0;
            document.querySelectorAll('.award-admin-card').forEach(card => {
                const show = (status === 'all' || card.dataset.status === status) && card.dataset.title.includes(q);
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            document.getElementById('emptyState').style.display = visible === 0 ? 'block' : 'none';
        }
    </script>
</body>
</html>
