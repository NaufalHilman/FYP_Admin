<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Applications — <%= job.job_title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/careers.css">
    <link rel="stylesheet" href="/styles/applications.css">
    <style>
        .application-card { scroll-margin-top: 90px; }
        .application-card.highlight {
            animation: card-flash 1.6s ease forwards;
        }
        @keyframes card-flash {
            0%,20% { box-shadow: 0 0 0 3px #FFCB05; background: #fffbea; }
            100%    { box-shadow: none; background: #fff; }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar') %>
    <%- include('../partials/header') %>

    <main class="content">
        <div class="page-header">
            <h1>Applications — <%= job.job_title %></h1>
            <a href="/careers" class="btn-back"><i class="fas fa-arrow-left"></i> Back to Careers</a>        </div>

        <div class="job-meta-row">
            <% if (job.department) { %><span><%= job.department %></span><% } %>
            <% if (job.location) { %><span><%= job.location %></span><% } %>
        </div>

        <% if (applications.length === 0) { %>
            <div class="no-apps">
                <i class="fas fa-inbox"></i>
                <p>No applications received yet.</p>
            </div>
        <% } else { %>

        <% 
            const withResume = applications.filter(a => a.resume_path).length;
            const weekAgo = new Date(); weekAgo.setDate(weekAgo.getDate() - 7);
            const thisWeek = applications.filter(a => new Date(a.submitted_at) >= weekAgo).length;
        %>
        <div class="stats-row">
            <div class="stat-box">
                <div class="num"><%= applications.length %></div>
                <div class="lbl">Total Applicants</div>
            </div>
            <div class="stat-box stat-box--gold">
                <div class="num"><%= withResume %></div>
                <div class="lbl">With Resume</div>
            </div>
            <div class="stat-box stat-box--accent">
                <div class="num"><%= thisWeek %></div>
                <div class="lbl">This Week</div>
            </div>
        </div>

        <div class="applications-list">
            <% applications.forEach(app => { %>
            <div class="application-card" id="app-<%= app.id %>">
                <div class="applicant-header">
                    <div class="applicant-avatar">
                        <%= app.full_name.charAt(0).toUpperCase() %>
                    </div>
                    <div class="applicant-info">
                        <h4><%= app.full_name %></h4>
                        <p>
                            <i class="fas fa-envelope"></i> <%= app.email %>
                            <% if (app.phone) { %> &nbsp;·&nbsp; <i class="fas fa-phone"></i> <%= app.phone %><% } %>
                        </p>
                    </div>
                    <span class="app-date">
                        <%= new Date(app.submitted_at).toLocaleDateString('en-SG', { year:'numeric', month:'short', day:'numeric' }) %>
                    </span>
                </div>

                <% if (app.cover_letter) { %>
                <div class="cover-letter">
                    <strong><i class="fas fa-quote-left"></i> Cover Letter</strong>
                    <p><%= app.cover_letter %></p>
                </div>
                <% } %>

                <div class="card-footer">
                    <% if (app.resume_path) { %>
                    <a href="<%= app.resume_path %>" target="_blank" class="btn-resume">
                        <i class="fas fa-file-alt"></i> View Resume
                    </a>
                    <% } else { %>
                    <span class="no-resume">No resume attached</span>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        <% } %>
    </main>
<script>
    const hash = window.location.hash;
    if (hash && hash.startsWith('#app-')) {
        const target = document.querySelector(hash);
        if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            target.classList.add('highlight');
        }
    }
</script>
</body>
</html>