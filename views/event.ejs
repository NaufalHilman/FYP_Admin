<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/careers.css">
</head>
<body>
    <%- include('../partials/sidebar') %>
    <%- include('../partials/header') %>

    <%
    function toDateInput(d) {
        if (!d) return '';
        const dt = new Date(d);
        const y = dt.getFullYear();
        const m = String(dt.getMonth() + 1).padStart(2, '0');
        const day = String(dt.getDate()).padStart(2, '0');
        return `${y}-${m}-${day}`;
    }
    const today = new Date(); today.setHours(0, 0, 0, 0);
    const upcomingCount = events.filter(e => new Date(e.event_date) >= today).length;
    const featuredCount = events.filter(e => e.is_featured).length;
    %>

    <main class="content">
        <div class="page-header">
            <h1>Events Management</h1>
            <div class="search-box">
                <i class="fa fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search" oninput="filterEvents()">
            </div>
            <button class="btn-update" onclick="openModal()">+ New Event</button>
        </div>

        <div class="main-layout">
            <aside class="sidebar-info">
                <!-- Compact stats row -->
                <div class="stats-row-card">
                    <div class="stats-mini">
                        <div class="stats-num"><%= events.length %></div>
                        <div class="stats-label">Total</div>
                    </div>
                    <div class="stats-divider"></div>
                    <div class="stats-mini">
                        <div class="stats-num"><%= upcomingCount %></div>
                        <div class="stats-label">Upcoming</div>
                    </div>
                    <div class="stats-divider"></div>
                    <div class="stats-mini">
                        <div class="stats-num"><%= featuredCount %></div>
                        <div class="stats-label">Featured</div>
                    </div>
                </div>

                <!-- Quick registrations view -->
                <div class="apps-card">
                    <h4><i class="fas fa-users"></i> Registrations</h4>
                    <% events.forEach(e => { %>
                    <a href="/events/registrations/<%= e.id %>" class="app-row">
                        <span class="app-count <%= (regCounts[e.id] || 0) === 0 ? 'zero' : '' %>">
                            <%= regCounts[e.id] || 0 %>
                        </span>
                        <span class="app-label"><%= e.title %></span>
                        <i class="fas fa-chevron-right app-arrow"></i>
                    </a>
                    <% }) %>
                </div>
            </aside>

            <section class="job-grid" id="eventGrid">
                <% events.forEach(event => { %>
                <div class="job-card" data-title="<%= event.title.toLowerCase() %>">

                    <a href="/events/registrations/<%= event.id %>" class="btn-registrations">
                        <i class="fas fa-users"></i>
                        Registrations
                        <span class="reg-badge <%= (regCounts[event.id] || 0) === 0 ? 'reg-badge--zero' : '' %>">
                            <%= regCounts[event.id] || 0 %>
                        </span>
                    </a>

                    <form action="/events/update/<%= event.id %>" method="POST" enctype="multipart/form-data">
                        <label>Title</label>
                        <input type="text" name="title" value="<%= event.title %>">

                        <label>Category</label>
                        <select name="category">
                            <option value="networking" <%= event.category === 'networking' ? 'selected' : '' %>>Networking</option>
                            <option value="workshop"   <%= event.category === 'workshop'   ? 'selected' : '' %>>Workshop</option>
                        </select>

                        <label>Date</label>
                        <input type="date" name="event_date" value="<%= toDateInput(event.event_date) %>">

                        <label>Location</label>
                        <input type="text" name="location" value="<%= event.location || '' %>">

                        <label>Description</label>
                        <textarea name="description" rows="4"><%= event.description %></textarea>

                        <label>Register link</label>
                        <input type="url" name="register_link" value="<%= event.register_link || '' %>">

                        <label class="checkbox-row">
                            <input type="checkbox" name="is_featured" <%= event.is_featured ? 'checked' : '' %>>
                            Featured event
                        </label>

                        <label>Image</label>
                        <div class="img-row">
                            <div class="img-thumb">
                                <img id="preview-<%= event.id %>"
                                     src="<%= event.image_path || '/images/placeholder.jpg' %>"
                                     alt="Event image">
                            </div>
                            <label class="img-placeholder">
                                <i class="fa fa-upload"></i>
                                <span>Replace</span>
                                <input type="file" name="image" accept="image/*" hidden
                                       onchange="previewImage(this, 'preview-<%= event.id %>')">
                            </label>
                        </div>

                        <div class="card-actions">
                            <button type="submit" class="btn-update">UPDATE</button>
                        </div>
                    </form>

                    <form action="/events/delete/<%= event.id %>" method="POST"
                          onsubmit="return confirm('Remove this event?')">
                        <button type="submit" class="btn-remove">REMOVE</button>
                    </form>
                </div>
                <% }) %>
            </section>
        </div>

        <!-- Create New Event Modal -->
        <div id="createModal" class="modal-overlay" style="display:none;">
            <div class="modal">
                <h3>Create New Event</h3>
                <form action="/events/create" method="POST" enctype="multipart/form-data">
                    <label>Title</label>
                    <input type="text" name="title" required>

                    <label>Category</label>
                    <select name="category">
                        <option value="networking">Networking</option>
                        <option value="workshop">Workshop</option>
                    </select>

                    <label>Date</label>
                    <input type="date" name="event_date" required>

                    <label>Location</label>
                    <input type="text" name="location">

                    <label>Description</label>
                    <textarea name="description" rows="4"></textarea>

                    <label>Register link</label>
                    <input type="url" name="register_link">

                    <label class="checkbox-row">
                        <input type="checkbox" name="is_featured">
                        Featured event
                    </label>

                    <label>Image</label>
                    <div class="img-row">
                        <div class="img-thumb">
                            <img id="new-preview" src="/images/placeholder.jpg" alt="">
                        </div>
                        <label class="img-placeholder">
                            <i class="fa fa-upload"></i>
                            <span>Choose Image</span>
                            <input type="file" name="image" accept="image/*" hidden
                                   onchange="previewImage(this, 'new-preview')">
                        </label>
                    </div>

                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
                        <button type="submit" class="btn-update">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script>
        function previewImage(input, targetId) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById(targetId).src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }
        function openModal()  { document.getElementById('createModal').style.display = 'flex'; }
        function closeModal() { document.getElementById('createModal').style.display = 'none'; }
        function filterEvents() {
            const q = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('.job-card').forEach(card => {
                card.style.display = card.dataset.title.includes(q) ? '' : 'none';
            });
        }
    </script>
</body>
</html>