<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact — ARDE</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8fafc;
            color: #1f2937;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 60px 20px;
        }
        .card {
            background: #fff;
            border-radius: 16px;
            padding: 32px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        }
        h1 {
            margin-top: 0;
            color: #27247B;
        }
        .social-links {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 24px;
        }
        .social-links a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 16px;
            border-radius: 999px;
            background: #f1f5f9;
            color: #334155;
            text-decoration: none;
            font-weight: 600;
        }
        .social-links a:hover {
            background: #27247B;
            color: #fff;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h1>Contact Us</h1>
            <p>Follow us on our social channels or use the links below.</p>

            <div class="social-links">
                <% if (settings.twitter_url) { %>
                    <a href="<%= settings.twitter_url %>" target="_blank" rel="noopener noreferrer"><i class="fab fa-x-twitter"></i> X / Twitter</a>
                <% } %>
                <% if (settings.instagram_url) { %>
                    <a href="<%= settings.instagram_url %>" target="_blank" rel="noopener noreferrer"><i class="fab fa-instagram"></i> Instagram</a>
                <% } %>
                <% if (settings.linkedin_url) { %>
                    <a href="<%= settings.linkedin_url %>" target="_blank" rel="noopener noreferrer"><i class="fab fa-linkedin"></i> LinkedIn</a>
                <% } %>
            </div>

            <% if (settings.email_address || settings.phone_number || settings.address || settings.website_url || settings.map_url) { %>
                <p>
                    <% if (settings.email_address) { %>
                        Email: <a href="mailto:<%= settings.email_address %>"><%= settings.email_address %></a><br>
                    <% } %>
                    <% if (settings.phone_number) { %>
                        Phone: <%= settings.phone_number %><br>
                    <% } %>
                    <% if (settings.address) { %>
                        Address: <%= settings.address %><br>
                    <% } %>
                    <% if (settings.website_url) { %>
                        Website: <a href="<%= settings.website_url %>" target="_blank" rel="noopener noreferrer"><%= settings.website_url %></a><br>
                    <% } %>
                    <% if (settings.map_url) { %>
                        Map: <a href="<%= settings.map_url %>" target="_blank" rel="noopener noreferrer">Open map</a>
                    <% } %>
                </p>
            <% } %>
        </div>
    </div>
</body>
</html>
