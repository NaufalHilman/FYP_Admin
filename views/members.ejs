<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Management</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/careers.css">
    <link rel="stylesheet" href="/styles/members-admin.css">
    <link rel="stylesheet" href="/styles/upload-preview.css">
    <script src="/scripts/upload-preview.js" defer></script>
</head>
<body>
    <%- include('../partials/sidebar') %>
    <%- include('../partials/header') %>

    <main class="content">
        <div class="page-header">
            <h1>Members Management</h1>
        </div>

        <% if (error) { %>
        <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i> <%= error %>
        </div>
        <% } %>
        <% if (notice) { %>
        <div class="alert alert-notice">
            <i class="fas fa-check-circle"></i> <%= notice %>
        </div>
        <% } %>

        <!-- TABS -->
        <% const pendingApps = applications.filter(a => a.status === 'pending'); %>
        <div class="tabs">
            <button class="tab-btn active" data-tab="arde">ARDE Members</button>
            <button class="tab-btn" data-tab="honorary">Honorary Members</button>
            <button class="tab-btn" data-tab="executive">Executive Committee</button>
            <button class="tab-btn" data-tab="applications">
                Applications
                <% if (pendingApps.length > 0) { %>
                <span class="tab-badge"><%= pendingApps.length %></span>
                <% } %>
            </button>
        </div>

        <!-- ============================= -->
        <!-- TAB 1: ARDE MEMBERS -->
        <!-- ============================= -->
        <div class="tab-panel active" id="tab-arde">
            <div class="panel-header">
                <h3><span id="arde-count"><%= members.length %></span> Members</h3>
                <div class="filter-bar">
                    <div class="search-box">
                        <i class="fa fa-search"></i>
                        <input type="text" id="arde-search" placeholder="Search name or company…" oninput="filterArde()">
                    </div>
                    <select id="arde-status-filter" onchange="filterArde()" class="filter-select">
                        <option value="all">All</option>
                        <option value="active">Active</option>
                        <option value="expired">Expired</option>
                        <option value="none">No expiry set</option>
                    </select>
                    <button class="btn-add" onclick="openModal('createMemberModal')">
                        <i class="fas fa-plus"></i> Add Member
                    </button>
                </div>
            </div>

            <% if (members.length === 0) { %>
                <p class="no-data">No members added yet.</p>
            <% } else { %>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Photo</th>
                        <th>Member ID</th>
                        <th>Name</th>
                        <th>Company / Hotel</th>
                        <th>Valid Till</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="arde-tbody">
                    <% members.forEach(m => {
                        const vt = m.valid_till ? new Date(m.valid_till) : null;
                        const status = !vt ? 'none' : (vt >= new Date() ? 'active' : 'expired');
                    %>
                    <tr data-name="<%= m.full_name.toLowerCase() %>"
                        data-company="<%= (m.company || '').toLowerCase() %>"
                        data-vstatus="<%= status %>">
                        <td>
                            <% if (m.image_path) { %>
                                <img src="<%= m.image_path %>" alt="<%= m.full_name %>" class="table-avatar">
                            <% } else { %>
                                <div class="table-avatar table-avatar--placeholder"><%= m.full_name.charAt(0) %></div>
                            <% } %>
                        </td>
                        <td><code class="member-id-chip"><%= m.member_id || '—' %></code></td>
                        <td><%= m.title ? m.title + ' ' : '' %><%= m.full_name %><% if (m.membership_tier) { %><span class="app-tier-badge"><%= m.membership_tier %></span><% } %></td>
                        <td><%= m.company || '—' %></td>
                        <td><%= vt ? vt.toLocaleDateString('en-SG', { year:'numeric', month:'short', day:'numeric' }) : '—' %></td>
                        <td class="actions-cell">
                            <button class="btn-icon btn-edit-member" data-member='<%- JSON.stringify(m).replace(/'/g, "&#39;") %>'>
                                <i class="fas fa-pen"></i>
                            </button>
                            <form action="/members/delete/<%= m.id %>" method="POST" onsubmit="return confirm('Remove this member?')" class="form-inline">
                                <button type="submit" class="btn-icon btn-icon--danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <p id="arde-no-results" class="no-data" style="display:none;">No members match your search.</p>
            <% } %>
        </div>

        <!-- ============================= -->
        <!-- TAB 2: HONORARY MEMBERS -->
        <!-- ============================= -->
        <div class="tab-panel" id="tab-honorary">
            <div class="panel-header">
                <h3><span id="honorary-count"><%= honorary.length %></span> Honorary Members</h3>
                <div class="filter-bar">
                    <div class="search-box">
                        <i class="fa fa-search"></i>
                        <input type="text" id="honorary-search" placeholder="Search name or title…" oninput="filterHonorary()">
                    </div>
                    <button class="btn-add" onclick="openModal('createHonoraryModal')">
                        <i class="fas fa-plus"></i> Add Honorary Member
                    </button>
                </div>
            </div>

            <% if (honorary.length === 0) { %>
                <p class="no-data">No honorary members added yet.</p>
            <% } else { %>
            <div class="member-card-grid" id="honorary-grid">
                <% honorary.forEach(h => { %>
                <div class="member-card"
                     data-name="<%= h.full_name.toLowerCase() %>"
                     data-title="<%= (h.title || '').toLowerCase() %>">
                    <div class="member-card-photo">
                        <% if (h.image_path) { %>
                            <img src="<%= h.image_path %>" alt="<%= h.full_name %>">
                        <% } else { %>
                            <div class="photo-placeholder"><%= h.full_name.charAt(0) %></div>
                        <% } %>
                    </div>
                    <h4><%= h.full_name %></h4>
                    <p class="member-card-title"><%= h.title || '—' %></p>
                    <% if (h.description) { %><p class="member-card-desc"><%= h.description %></p><% } %>
                    <div class="member-card-actions">
                        <button class="btn-icon btn-edit-honorary" data-member='<%- JSON.stringify(h).replace(/'/g, "&#39;") %>'>
                            <i class="fas fa-pen"></i>
                        </button>
                        <form action="/members/honorary/delete/<%= h.id %>" method="POST" onsubmit="return confirm('Remove this honorary member?')" style="display:inline;">
                            <button type="submit" class="btn-icon btn-icon--danger">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
                <% }) %>
            </div>
            <p id="honorary-no-results" class="no-data" style="display:none;">No honorary members match your search.</p>
            <% } %>
        </div>

        <!-- ============================= -->
        <!-- TAB 3: EXECUTIVE COMMITTEE -->
        <!-- ============================= -->
        <div class="tab-panel" id="tab-executive">
            <div class="panel-header">
                <h3>Executive Committee</h3>
                <div class="filter-bar">
                    <div class="search-box">
                        <i class="fa fa-search"></i>
                        <input type="text" id="exec-search" placeholder="Search name or title…" oninput="filterExec()">
                    </div>
                    <select id="exec-group-filter" onchange="filterExec()" class="filter-select">
                        <option value="all">All Groups</option>
                        <% groups.forEach(g => { %>
                        <option value="<%= g.id %>"><%= g.group_name %></option>
                        <% }) %>
                    </select>
                    <div class="panel-header-actions">
                        <button class="btn-add btn-add--secondary" onclick="openModal('manageGroupsModal')">
                            <i class="fas fa-layer-group"></i> Manage Groups
                        </button>
                        <button class="btn-add" onclick="openModal('createExecutiveModal')">
                            <i class="fas fa-plus"></i> Add Member
                        </button>
                    </div>
                </div>
            </div>

            <% if (president) { %>
            <div class="president-banner">
                <span class="president-banner-tag"><i class="fas fa-crown"></i> Current President</span>
                <h4><%= president.full_name %></h4>
                <p><%= president.president_vision %></p>
            </div>
            <% } %>

            <div id="exec-groups-container">
            <% groupedExecutives.forEach(group => { %>
            <div class="exec-group-block" data-group-id="<%= group.id %>">
                <h3 class="exec-group-title"><%= group.group_name %></h3>
                <% if (group.members.length === 0) { %>
                    <p class="no-data-inline">No members in this group yet.</p>
                <% } else { %>
                <div class="member-card-grid">
                    <% group.members.forEach(member => { %>
                    <div class="member-card exec-card"
                         data-name="<%= member.full_name.toLowerCase() %>"
                         data-title="<%= (member.title || '').toLowerCase() %>"
                         data-group="<%= member.group_id %>">
                        <% if (member.is_president) { %><span class="president-badge"><i class="fas fa-crown"></i></span><% } %>
                        <div class="member-card-photo">
                            <% if (member.image_path) { %>
                                <img src="<%= member.image_path %>" alt="<%= member.full_name %>">
                            <% } else { %>
                                <div class="photo-placeholder"><%= member.full_name.charAt(0) %></div>
                            <% } %>
                        </div>
                        <h4><%= member.full_name %></h4>
                        <p class="member-card-title"><%= member.title %></p>
                        <% if (member.description) { %><p class="member-card-desc"><%= member.description %></p><% } %>
                        <div class="member-card-actions">
                            <button class="btn-icon btn-edit-exec" data-member='<%- JSON.stringify(member).replace(/'/g, "&#39;") %>'>
                                <i class="fas fa-pen"></i>
                            </button>
                            <form action="/members/executive/delete/<%= member.id %>" method="POST" onsubmit="return confirm('Remove this member?')" style="display:inline;">
                                <button type="submit" class="btn-icon btn-icon--danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } %>
            </div>
            <% }) %>
            </div>
            <p id="exec-no-results" class="no-data" style="display:none;">No members match your search.</p>
        </div>

        <!-- ============================= -->
        <!-- TAB 4: APPLICATIONS -->
        <!-- ============================= -->
        <div class="tab-panel" id="tab-applications">
            <%
                const appPending  = applications.filter(a => a.status === 'pending');
                const appAccepted = applications.filter(a => a.status === 'accepted');
            %>

            <div class="panel-header">
                <h3>Membership Applications</h3>
                <div class="filter-bar">
                    <div class="search-box">
                        <i class="fa fa-search"></i>
                        <input type="text" id="app-search" placeholder="Search name or email…" oninput="filterApps()">
                    </div>
                    <select id="app-status-filter" onchange="filterApps()" class="filter-select">
                        <option value="all">All Statuses</option>
                        <option value="pending">Pending</option>
                        <option value="accepted">Accepted</option>
                        <option value="declined">Declined</option>
                    </select>
                </div>
            </div>

            <div class="app-stats-row">
                <div class="stat-box stat-box--total">
                    <div class="stat-num"><%= applications.length %></div>
                    <div class="stat-lbl">Total Applications</div>
                </div>
                <div class="stat-box stat-box--pending">
                    <div class="stat-num stat-num--pending"><%= appPending.length %></div>
                    <div class="stat-lbl">Pending Review</div>
                </div>
                <div class="stat-box stat-box--accepted">
                    <div class="stat-num stat-num--accepted"><%= appAccepted.length %></div>
                    <div class="stat-lbl">Accepted Members</div>
                </div>
            </div>

            <% if (applications.length === 0) { %>
                <p class="no-data"><i class="fas fa-inbox"></i> No membership applications yet.</p>
            <% } else { %>
            <div class="applications-list" id="app-list">
                <% applications.forEach(app => { %>
                <div class="application-card"
                     data-name="<%= app.full_name.toLowerCase() %>"
                     data-email="<%= (app.personal_email || '').toLowerCase() %>"
                     data-status="<%= app.status %>">

                    <div class="applicant-header">
                        <div class="applicant-avatar">
                            <%= app.full_name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="applicant-info">
                            <h4 class="applicant-name">
                                <%= app.title ? app.title + ' ' : '' %><%= app.full_name %>
                                <span class="app-type-badge"><%= app.membership_type %></span>
                                <% if (app.membership_tier) { %><span class="app-tier-badge"><%= app.membership_tier %></span><% } %>
                            </h4>
                            <p class="applicant-contact">
                                <i class="fas fa-envelope"></i> <%= app.personal_email %>
                                <% if (app.mobile_number) { %> &nbsp;·&nbsp; <i class="fas fa-phone"></i> <%= app.mobile_number %><% } %>
                            </p>
                        </div>
                        <span class="app-status-badge app-status-badge--<%= app.status %>"><%= app.status %></span>
                    </div>

                    <div class="app-details-grid">
                        <div><span class="app-detail-label">Nationality</span><%= app.nationality || '—' %></div>
                        <div><span class="app-detail-label">Date of Birth</span><%= app.date_of_birth ? new Date(app.date_of_birth).toLocaleDateString('en-SG', {year:'numeric',month:'short',day:'numeric'}) : '—' %></div>
                        <div><span class="app-detail-label">Hotel</span><%= app.hotel_name || '—' %></div>
                        <div><span class="app-detail-label">Current Position</span><%= app.current_position || '—' %></div>
                        <div><span class="app-detail-label">Years in Position</span><%= app.years_in_position || '—' %></div>
                        <div><span class="app-detail-label">Business Email</span><%= app.business_email || '—' %></div>
                        <div><span class="app-detail-label">Telephone</span><%= app.telephone_number || '—' %></div>
                        <div><span class="app-detail-label">Residential Address</span><%= app.residential_address || '—' %></div>
                        <div><span class="app-detail-label">Business Address</span><%= app.business_address || '—' %></div>
                    </div>

                    <div class="app-footer">
                        <% if (app.status === 'accepted') { %>
                            <span class="app-member-id"><i class="fas fa-id-card"></i> Member ID: <strong><%= app.member_id || app.existing_member_id || '—' %></strong></span>
                            <form action="/membership/delete/<%= app.id %>" method="POST" onsubmit="return confirm('Delete this application record?')" class="form-inline">
                                <button type="submit" class="btn-app-delete"><i class="fas fa-trash"></i> Delete</button>
                            </form>
                        <% } else if (app.status === 'declined') { %>
                            <span class="app-declined-label"><i class="fas fa-xmark"></i> Declined</span>
                            <form action="/membership/delete/<%= app.id %>" method="POST" onsubmit="return confirm('Delete this application record?')" class="form-inline">
                                <button type="submit" class="btn-app-delete"><i class="fas fa-trash"></i> Delete</button>
                            </form>
                        <% } else { %>
                            <% if (app.membership_type === 'Renew') { %>
                                <span class="app-renew-note"><i class="fas fa-rotate"></i> Renewing ID: <strong><%= app.existing_member_id || '—' %></strong></span>
                            <% } %>
                            <form action="/membership/accept/<%= app.id %>" method="POST"
                                  onsubmit="return confirm('Accept this application? This will auto-add them to ARDE Members.');" class="form-inline">
                                <button type="submit" class="btn-app-accept"><i class="fas fa-check"></i> Accept</button>
                            </form>
                            <form action="/membership/decline/<%= app.id %>" method="POST"
                                  onsubmit="return confirm('Decline this application?');" class="form-inline">
                                <button type="submit" class="btn-app-decline"><i class="fas fa-xmark"></i> Decline</button>
                            </form>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
            <p id="app-no-results" class="no-data" style="display:none;">No applications match your search.</p>
            <% } %>
        </div>

        <!-- ============================================= -->
        <!-- MODAL: Create ARDE Member -->
        <!-- ============================================= -->
        <div id="createMemberModal" class="modal-overlay">
            <div class="modal">
                <h3>Add Member</h3>
                <form action="/members/create" method="POST" enctype="multipart/form-data">
                    <label>Title</label>
                    <select name="title">
                        <option value="">—</option>
                        <option>Mr</option>
                        <option>Mrs</option>
                        <option>Ms</option>
                        <option>Dr</option>
                        <option>Prof</option>
                    </select>
                    <label>Full Name</label>
                    <input type="text" name="full_name" required>
                    <label>Company / Hotel</label>
                    <input type="text" name="company">
                    <label>Membership Tier</label>
                    <select name="membership_tier">
                        <option value="">— Select tier —</option>
                        <option>Ordinary</option>
                        <option>Associate</option>
                        <option>Junior</option>
                        <option>Corporate</option>
                        <option>Honorary</option>
                    </select>
                    <label>Valid Till</label>
                    <input type="date" name="valid_till">
                    <label>Photo</label>
                    <input type="file" name="image" accept="image/*">
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal('createMemberModal')">Cancel</button>
                        <button type="submit" class="btn-update">Add Member</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- MODAL: Edit ARDE Member -->
        <div id="editMemberModal" class="modal-overlay">
            <div class="modal">
                <h3>Edit Member</h3>
                <form id="editMemberForm" method="POST" enctype="multipart/form-data">
                    <label>Title</label>
                    <select name="title" id="edit-member-title">
                        <option value="">—</option>
                        <option>Mr</option>
                        <option>Mrs</option>
                        <option>Ms</option>
                        <option>Dr</option>
                        <option>Prof</option>
                    </select>
                    <label>Full Name</label>
                    <input type="text" name="full_name" id="edit-member-name" required>
                    <label>Company / Hotel</label>
                    <input type="text" name="company" id="edit-member-company">
                    <label>Membership Tier</label>
                    <select name="membership_tier" id="edit-member-tier">
                        <option value="">— Select tier —</option>
                        <option>Ordinary</option>
                        <option>Associate</option>
                        <option>Junior</option>
                        <option>Corporate</option>
                        <option>Honorary</option>
                    </select>
                    <label>Valid Till</label>
                    <input type="date" name="valid_till" id="edit-member-valid">
                    <div id="edit-member-photo-preview" class="current-photo-preview" style="display:none;">
                        <img id="edit-member-photo-img" src="" alt="Current photo">
                        <span>Current photo</span>
                    </div>
                    <label>Photo (leave blank to keep current)</label>
                    <input type="file" name="image" accept="image/*">
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal('editMemberModal')">Cancel</button>
                        <button type="submit" class="btn-update">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ============================================= -->
        <!-- MODAL: Create Honorary Member -->
        <!-- ============================================= -->
        <div id="createHonoraryModal" class="modal-overlay">
            <div class="modal">
                <h3>Add Honorary Member</h3>
                <form action="/members/honorary/create" method="POST" enctype="multipart/form-data">
                    <label>Full Name</label>
                    <input type="text" name="full_name" required>
                    <label>Title</label>
                    <input type="text" name="title" placeholder="e.g. Honorary Member">
                    <label>Description</label>
                    <textarea name="description" rows="3"></textarea>
                    <label>Display Order</label>
                    <input type="number" name="display_order" value="0">
                    <label>Photo</label>
                    <input type="file" name="image" accept="image/*">
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal('createHonoraryModal')">Cancel</button>
                        <button type="submit" class="btn-update">Add Member</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- MODAL: Edit Honorary Member -->
        <div id="editHonoraryModal" class="modal-overlay">
            <div class="modal">
                <h3>Edit Honorary Member</h3>
                <form id="editHonoraryForm" method="POST" enctype="multipart/form-data">
                    <label>Full Name</label>
                    <input type="text" name="full_name" id="edit-honorary-name" required>
                    <label>Title</label>
                    <input type="text" name="title" id="edit-honorary-title">
                    <label>Description</label>
                    <textarea name="description" id="edit-honorary-desc" rows="3"></textarea>
                    <label>Display Order</label>
                    <input type="number" name="display_order" id="edit-honorary-order">
                    <label>Photo (leave blank to keep current)</label>
                    <input type="file" name="image" accept="image/*">
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal('editHonoraryModal')">Cancel</button>
                        <button type="submit" class="btn-update">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ============================================= -->
        <!-- MODAL: Create Executive Member -->
        <!-- ============================================= -->
        <div id="createExecutiveModal" class="modal-overlay">
            <div class="modal">
                <h3>Add Executive Member</h3>
                <form action="/members/executive/create" method="POST" enctype="multipart/form-data">
                    <label>Group</label>
                    <select name="group_id" required>
                        <% groups.forEach(g => { %>
                            <option value="<%= g.id %>"><%= g.group_name %></option>
                        <% }) %>
                    </select>
                    <label>Full Name</label>
                    <input type="text" name="full_name" required>
                    <label>Title</label>
                    <input type="text" name="title" placeholder="e.g. Vice President">
                    <label>Description</label>
                    <textarea name="description" rows="3"></textarea>
                    <label class="checkbox-label">
                        <input type="checkbox" name="is_president" id="create-is-president">
                        Set as Current President
                    </label>
                    <div id="create-president-vision-wrap" style="display:none;">
                        <label>President Vision Statement (2 lines)</label>
                        <textarea name="president_vision" rows="2"></textarea>
                    </div>
                    <label>Display Order</label>
                    <input type="number" name="display_order" value="0">
                    <label>Photo</label>
                    <input type="file" name="image" accept="image/*">
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal('createExecutiveModal')">Cancel</button>
                        <button type="submit" class="btn-update">Add Member</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- MODAL: Edit Executive Member -->
        <div id="editExecutiveModal" class="modal-overlay">
            <div class="modal">
                <h3>Edit Executive Member</h3>
                <form id="editExecutiveForm" method="POST" enctype="multipart/form-data">
                    <label>Group</label>
                    <select name="group_id" id="edit-exec-group" required>
                        <% groups.forEach(g => { %>
                            <option value="<%= g.id %>"><%= g.group_name %></option>
                        <% }) %>
                    </select>
                    <label>Full Name</label>
                    <input type="text" name="full_name" id="edit-exec-name" required>
                    <label>Title</label>
                    <input type="text" name="title" id="edit-exec-title">
                    <label>Description</label>
                    <textarea name="description" id="edit-exec-desc" rows="3"></textarea>
                    <label class="checkbox-label">
                        <input type="checkbox" name="is_president" id="edit-is-president">
                        Set as Current President
                    </label>
                    <div id="edit-president-vision-wrap" style="display:none;">
                        <label>President Vision Statement (2 lines)</label>
                        <textarea name="president_vision" id="edit-exec-vision" rows="2"></textarea>
                    </div>
                    <label>Display Order</label>
                    <input type="number" name="display_order" id="edit-exec-order">
                    <label>Photo (leave blank to keep current)</label>
                    <input type="file" name="image" accept="image/*">
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal('editExecutiveModal')">Cancel</button>
                        <button type="submit" class="btn-update">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ============================================= -->
        <!-- MODAL: Manage Groups -->
        <!-- ============================================= -->
        <div id="manageGroupsModal" class="modal-overlay">
            <div class="modal modal--wide">
                <h3>Manage Executive Groups</h3>

                <div class="groups-list">
                    <% groups.forEach(g => { %>
                    <div class="group-row">
                        <form action="/members/groups/update/<%= g.id %>" method="POST" class="group-row-form">
                            <input type="text" name="group_name" value="<%= g.group_name %>" required>
                            <input type="number" name="display_order" value="<%= g.display_order %>" class="order-input">
                            <button type="submit" class="btn-icon"><i class="fas fa-check"></i></button>
                        </form>
                        <form action="/members/groups/delete/<%= g.id %>" method="POST" onsubmit="return confirm('Delete this group? Members inside will also be removed.')">
                            <button type="submit" class="btn-icon btn-icon--danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                    <% }) %>
                </div>

                <hr class="modal-divider">

                <form action="/members/groups/create" method="POST" class="new-group-form">
                    <label>New Group Name</label>
                    <input type="text" name="group_name" placeholder="e.g. Partnerships & Sponsorship" required>
                    <label>Display Order</label>
                    <input type="number" name="display_order" value="0">
                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal('manageGroupsModal')">Close</button>
                        <button type="submit" class="btn-update">Add Group</button>
                    </div>
                </form>
            </div>
        </div>

    </main>

    <script>
        // ===== TABS =====
        function activateTab(tabKey) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            const btn = document.querySelector(`.tab-btn[data-tab="${tabKey}"]`);
            const panel = document.getElementById('tab-' + tabKey);
            if (btn && panel) {
                btn.classList.add('active');
                panel.classList.add('active');
            }
        }

        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                activateTab(btn.dataset.tab);
                localStorage.setItem('membersActiveTab', btn.dataset.tab);
            });
        });

        // URL param takes priority (used after accept/decline redirects), then localStorage
        const urlTab = new URLSearchParams(window.location.search).get('tab');
        if (urlTab) {
            activateTab(urlTab);
        } else {
            const savedTab = localStorage.getItem('membersActiveTab');
            if (savedTab) activateTab(savedTab);
        }

        // ===== MODAL HELPERS =====
        function openModal(id) {
            document.getElementById(id).style.display = 'flex';
        }
        function closeModal(id) {
            document.getElementById(id).style.display = 'none';
        }
        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', e => {
                if (e.target === overlay) overlay.style.display = 'none';
            });
        });

        // ===== EDIT ARDE MEMBER =====
        function openEditMember(m) {
            document.getElementById('edit-member-title').value = m.title || '';
            document.getElementById('edit-member-name').value = m.full_name;
            document.getElementById('edit-member-company').value = m.company || '';
            document.getElementById('edit-member-tier').value = m.membership_tier || '';
            document.getElementById('edit-member-valid').value = m.valid_till ? m.valid_till.split('T')[0] : '';
            document.getElementById('editMemberForm').action = '/members/update/' + m.id;

            const preview = document.getElementById('edit-member-photo-preview');
            if (m.image_path) {
                document.getElementById('edit-member-photo-img').src = m.image_path;
                preview.style.display = 'flex';
            } else {
                preview.style.display = 'none';
            }

            openModal('editMemberModal');
        }

        document.querySelectorAll('.btn-edit-member').forEach(btn => {
            btn.addEventListener('click', () => openEditMember(JSON.parse(btn.dataset.member)));
        });

        // ===== EDIT HONORARY MEMBER =====
        function openEditHonorary(h) {
            document.getElementById('edit-honorary-name').value = h.full_name;
            document.getElementById('edit-honorary-title').value = h.title || '';
            document.getElementById('edit-honorary-desc').value = h.description || '';
            document.getElementById('edit-honorary-order').value = h.display_order ?? 0;
            document.getElementById('editHonoraryForm').action = '/members/honorary/update/' + h.id;
            openModal('editHonoraryModal');
        }
        
        document.querySelectorAll('.btn-edit-honorary').forEach(btn => {
            btn.addEventListener('click', () => openEditHonorary(JSON.parse(btn.dataset.member)));
        });

        // ===== EDIT EXECUTIVE MEMBER =====
        function openEditExecutive(m) {
            document.getElementById('edit-exec-group').value = m.group_id;
            document.getElementById('edit-exec-name').value = m.full_name;
            document.getElementById('edit-exec-title').value = m.title || '';
            document.getElementById('edit-exec-desc').value = m.description || '';
            document.getElementById('edit-exec-order').value = m.display_order ?? 0;
            document.getElementById('edit-exec-vision').value = m.president_vision || '';

            const isPres = !!m.is_president;
            document.getElementById('edit-is-president').checked = isPres;
            document.getElementById('edit-president-vision-wrap').style.display = isPres ? 'block' : 'none';

            document.getElementById('editExecutiveForm').action = '/members/executive/update/' + m.id;
            openModal('editExecutiveModal');
        }

        document.querySelectorAll('.btn-edit-exec').forEach(btn => {
            btn.addEventListener('click', () => {
                const member = JSON.parse(btn.dataset.member);
                openEditExecutive(member);
            });
        });

        // ===== TOGGLE PRESIDENT VISION FIELD =====
        document.getElementById('create-is-president').addEventListener('change', function() {
            document.getElementById('create-president-vision-wrap').style.display = this.checked ? 'block' : 'none';
        });
        document.getElementById('edit-is-president').addEventListener('change', function() {
            document.getElementById('edit-president-vision-wrap').style.display = this.checked ? 'block' : 'none';
        });

        // ===== SEARCH & FILTER =====

        function filterArde() {
            const q = document.getElementById('arde-search').value.toLowerCase();
            const s = document.getElementById('arde-status-filter').value;
            const rows = document.querySelectorAll('#arde-tbody tr');
            let visible = 0;
            rows.forEach(row => {
                const nameMatch = row.dataset.name.includes(q) || row.dataset.company.includes(q);
                const statusMatch = s === 'all' || row.dataset.vstatus === s;
                const show = nameMatch && statusMatch;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            document.getElementById('arde-count').textContent = visible;
            const noRes = document.getElementById('arde-no-results');
            if (noRes) noRes.style.display = visible === 0 ? '' : 'none';
        }

        function filterHonorary() {
            const q = document.getElementById('honorary-search').value.toLowerCase();
            const cards = document.querySelectorAll('#honorary-grid .member-card');
            let visible = 0;
            cards.forEach(card => {
                const show = card.dataset.name.includes(q) || card.dataset.title.includes(q);
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            document.getElementById('honorary-count').textContent = visible;
            const noRes = document.getElementById('honorary-no-results');
            if (noRes) noRes.style.display = visible === 0 ? '' : 'none';
        }

        function filterExec() {
            const q = document.getElementById('exec-search').value.toLowerCase();
            const g = document.getElementById('exec-group-filter').value;
            let totalVisible = 0;
            document.querySelectorAll('#exec-groups-container .exec-group-block').forEach(block => {
                const groupId = block.dataset.groupId;
                const groupMatch = g === 'all' || groupId === g;
                let groupVisible = 0;
                block.querySelectorAll('.exec-card').forEach(card => {
                    const textMatch = card.dataset.name.includes(q) || card.dataset.title.includes(q);
                    const show = groupMatch && textMatch;
                    card.style.display = show ? '' : 'none';
                    if (show) groupVisible++;
                });
                // Hide entire group block if none of its cards are visible
                block.style.display = (groupMatch && groupVisible > 0) || (groupMatch && q === '' && g === 'all') ? '' : 'none';
                // If no search text but group filter active, show block even if cards hidden by other means
                if (groupMatch && groupVisible === 0 && q === '') block.style.display = '';
                totalVisible += groupVisible;
            });
            const noRes = document.getElementById('exec-no-results');
            if (noRes) noRes.style.display = totalVisible === 0 ? '' : 'none';
        }

        function filterApps() {
            const q = document.getElementById('app-search').value.toLowerCase();
            const s = document.getElementById('app-status-filter').value;
            const cards = document.querySelectorAll('#app-list .application-card');
            let visible = 0;
            cards.forEach(card => {
                const textMatch = card.dataset.name.includes(q) || card.dataset.email.includes(q);
                const statusMatch = s === 'all' || card.dataset.status === s;
                const show = textMatch && statusMatch;
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            const noRes = document.getElementById('app-no-results');
            if (noRes) noRes.style.display = visible === 0 ? '' : 'none';
        }
    </script>
</body>
</html>
