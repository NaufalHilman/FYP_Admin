<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <%- include('../partials/sidebar') %>
    <%- include('../partials/header') %>

    <div class="main-content">
        <div class="content-header">
            <h1>Dashboard Overview</h1>
            <p>Welcome back! Here is what is happening on your guest site today.</p>
        </div>

        <div class="card-grid">
            <div class="card card-blue">
                <div class="card-inner">
                    <div>
                        <h3>Active Events</h3>
                        <p class="card-number">0</p>
                    </div>
                    <i class="fas fa-calendar-alt card-icon"></i>
                </div>
            </div>

            <div class="card card-green">
                <div class="card-inner">
                    <div>
                        <h3>Career Listings</h3>
                        <p class="card-number"><%= jobCount %></p>
                    </div>
                    <i class="fas fa-briefcase card-icon"></i>
                </div>
            </div>

            <div class="card card-yellow">
                <div class="card-inner">
                    <div>
                        <h3>Total Applications</h3>
                        <p class="card-number"><%= appCount %></p>
                    </div>
                    <i class="fas fa-file-alt card-icon"></i>
                </div>
            </div>

            <div class="card card-red">
                <div class="card-inner">
                    <div>
                        <h3>Recent Announcements</h3>
                        <p class="card-number">0</p>
                    </div>
                    <i class="fas fa-bullhorn card-icon"></i>
                </div>
            </div>
        </div>
    </div>

</body>
</html>

<style>
body {
    margin: 0;
    background-color: #f8f9fc;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

.main-content {
    margin-left: 260px;
    padding: 100px 30px 30px 30px;
    min-height: calc(100vh - 100px);
}

.content-header h1 { margin: 0 0 10px 0; color: #3a3b45; }
.content-header p  { margin: 0 0 30px 0; color: #858796; }

.card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
}

.card {
    background: #fff;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    border-left: 4px solid transparent;
}

.card-blue   { border-left-color: #4e73df; }
.card-green  { border-left-color: #1cc88a; }
.card-yellow { border-left-color: #d79c07; }
.card-red    { border-left-color: #e74a3b; }

.card-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.card h3 {
    margin: 0 0 8px 0;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.card-blue   h3 { color: #4e73df; }
.card-green  h3 { color: #1cc88a; }
.card-yellow h3 { color: #d79c07; }
.card-red    h3 { color: #e74a3b; }

.card-number {
    margin: 0;
    font-size: 28px;
    font-weight: 700;
    color: #5a5c69;
}

.card-icon {
    font-size: 36px;
    opacity: 0.15;
}
</style>