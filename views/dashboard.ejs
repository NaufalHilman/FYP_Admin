<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard — ARDE</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/dashboard.css">
</head>
<body>

    <%- include('../partials/sidebar') %>
    <%- include('../partials/header') %>

    <div class="dash-main">

        <!-- ── PAGE HEADER ── -->
        <div class="dash-hdr">
            <div>
                <h1 class="dash-hdr__title">Dashboard</h1>
                <p class="dash-hdr__sub">
                    <% const now = new Date();
                       const dateStr = now.toLocaleDateString('en-SG', { weekday:'long', year:'numeric', month:'long', day:'numeric' }); %>
                    <%= dateStr %>
                </p>
            </div>
        </div>

        <!-- ── STAT CARDS ── -->
        <div class="stat-grid">

            <a href="/members" class="stat-card stat-card--navy">
                <div class="stat-card__icon"><i class="fas fa-users"></i></div>
                <div class="stat-card__body">
                    <p class="stat-card__num"><%= memberCount %></p>
                    <p class="stat-card__lbl">Total Members</p>
                </div>
            </a>

            <a href="/members?tab=applications" class="stat-card stat-card--yellow">
                <div class="stat-card__icon"><i class="fas fa-hourglass-half"></i></div>
                <div class="stat-card__body">
                    <p class="stat-card__num"><%= pendingApps %></p>
                    <p class="stat-card__lbl">Pending Member Applications</p>
                </div>
                <% if (pendingApps > 0) { %><span class="stat-card__dot"></span><% } %>
            </a>

            <a href="/events" class="stat-card stat-card--blue">
                <div class="stat-card__icon"><i class="fas fa-calendar-check"></i></div>
                <div class="stat-card__body">
                    <p class="stat-card__num"><%= eventCount %></p>
                    <p class="stat-card__lbl">Upcoming Events</p>
                </div>
            </a>

            <a href="/awards" class="stat-card stat-card--gold">
                <div class="stat-card__icon"><i class="fas fa-trophy"></i></div>
                <div class="stat-card__body">
                    <p class="stat-card__num"><%= openAwards %></p>
                    <p class="stat-card__lbl">Open Awards</p>
                </div>
            </a>

            <a href="/careers" class="stat-card stat-card--teal">
                <div class="stat-card__icon"><i class="fas fa-briefcase"></i></div>
                <div class="stat-card__body">
                    <p class="stat-card__num"><%= jobCount %></p>
                    <p class="stat-card__lbl">Career Listings</p>
                </div>
            </a>

            <a href="/careers" class="stat-card stat-card--purple">
                <div class="stat-card__icon"><i class="fas fa-file-alt"></i></div>
                <div class="stat-card__body">
                    <p class="stat-card__num"><%= appCount %></p>
                    <p class="stat-card__lbl">Job Applications</p>
                </div>
            </a>

        </div>

        <!-- ── LOWER PANELS ── -->
        <div class="dash-panels">

            <!-- Pending membership applications -->
            <div class="panel">
                <div class="panel__hdr">
                    <h2 class="panel__title"><i class="fas fa-clock"></i> Pending Member Applications</h2>
                    <a href="/members?tab=applications" class="panel__link">View all</a>
                </div>
                <% if (recentApps.length === 0) { %>
                    <div class="panel__empty">
                        <i class="fas fa-inbox"></i>
                        <p>No pending applications</p>
                    </div>
                <% } else { %>
                    <ul class="activity-list">
                        <% recentApps.forEach(a => { %>
                        <li class="activity-item">
                            <div class="activity-avatar"><%= a.full_name.charAt(0).toUpperCase() %></div>
                            <div class="activity-info">
                                <span class="activity-name"><%= a.full_name %></span>
                                <span class="activity-sub"><%= a.hotel_name || a.personal_email %></span>
                            </div>
                            <span class="activity-time">
                                <%= new Date(a.submitted_at).toLocaleDateString('en-SG', {day:'numeric',month:'short'}) %>
                            </span>
                        </li>
                        <% }) %>
                    </ul>
                <% } %>
            </div>

            <!-- Recent job applications -->
            <div class="panel">
                <div class="panel__hdr">
                    <h2 class="panel__title"><i class="fas fa-file-signature"></i> Recent Job Applications</h2>
                    <a href="/careers" class="panel__link">View all</a>
                </div>
                <% if (recentJobApps.length === 0) { %>
                    <div class="panel__empty">
                        <i class="fas fa-inbox"></i>
                        <p>No job applications yet</p>
                    </div>
                <% } else { %>
                    <ul class="activity-list">
                        <% recentJobApps.forEach(a => { %>
                        <li class="activity-item">
                            <a href="/careers/applications/<%= a.career_id %>#app-<%= a.id %>" class="activity-row-link">
                                <div class="activity-avatar activity-avatar--teal"><%= a.full_name.charAt(0).toUpperCase() %></div>
                                <div class="activity-info">
                                    <span class="activity-name"><%= a.full_name %></span>
                                    <span class="activity-sub"><%= a.job_title %></span>
                                </div>
                                <span class="activity-time">
                                    <%= new Date(a.submitted_at).toLocaleDateString('en-SG', {day:'numeric',month:'short'}) %>
                                </span>
                                <i class="fas fa-chevron-right activity-arrow"></i>
                            </a>
                        </li>
                        <% }) %>
                    </ul>
                <% } %>
            </div>


        </div>
    </div>

</body>
</html>


