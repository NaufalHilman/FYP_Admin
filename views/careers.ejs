<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Careers</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/careers.css">
</head>
<body>
    <%- include('../partials/sidebar') %>
    <%- include('../partials/header') %>

    <main class="content">
        <div class="page-header">
            <h1>Careers Management</h1>
            <div class="search-box">
                <i class="fa fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search" oninput="filterJobs()">
            </div>
        </div>

        <div class="main-layout">
            <aside class="sidebar-info">
                <div class="stats-card">
                    <div class="stats-num"><%= jobs.length %></div>
                    <div class="stats-label">Available Careers</div>
                </div>
                <div class="apps-card">
                    <h4>Applications Received</h4>
                    <% jobs.forEach(job => { %>
                    <div class="app-row">
                        <span class="app-count <%= (appCounts[job.id] || 0) === 0 ? 'zero' : '' %>">
                            <%= appCounts[job.id] || 0 %>
                        </span>
                        <a href="/careers/applications/<%= job.id %>" style="color:#333; text-decoration:none;">
                            <%= job.job_title %>
                        </a>
                    </div>
                    <% }) %>
                </div>
            </aside>

            <section class="job-grid" id="jobGrid">
                <% jobs.forEach(job => { %>
                <div class="job-card" data-title="<%= job.job_title.toLowerCase() %>">
                    <form action="/careers/update/<%= job.id %>" method="POST" enctype="multipart/form-data">
                        <label>Job Title</label>
                        <input type="text" name="job_title" value="<%= job.job_title %>">

                        <label>Department</label>
                        <input type="text" name="department" value="<%= job.department || '' %>">

                        <label>Location</label>
                        <input type="text" name="location" value="<%= job.location || '' %>">

                        <label>Description</label>
                        <textarea name="description" rows="5"><%= job.description %></textarea>

                        <label>Image</label>
                        <div class="img-row">
                            <div class="img-thumb">
                                <img id="preview-<%= job.id %>"
                                     src="<%= job.image_path || '/images/placeholder.jpg' %>"
                                     alt="Job image">
                            </div>
                            <label class="img-placeholder">
                                <i class="fa fa-upload"></i>
                                <span>Replace</span>
                                <input type="file" name="image" accept="image/*" hidden
                                       onchange="previewImage(this, 'preview-<%= job.id %>')">
                            </label>
                        </div>

                        <div class="card-actions">
                            <button type="submit" class="btn-update">UPDATE</button>
                        </div>
                    </form>

                    <form action="/careers/delete/<%= job.id %>" method="POST"
                          onsubmit="return confirm('Remove this job?')">
                        <button type="submit" class="btn-remove">REMOVE</button>
                    </form>
                </div>
                <% }) %>
            </section>
        </div>

        <!-- Create New Job Modal -->
        <div id="createModal" class="modal-overlay" style="display:none;">
            <div class="modal">
                <h3>Create New Job</h3>
                <form action="/careers/create" method="POST" enctype="multipart/form-data">
                    <label>Job Title</label>
                    <input type="text" name="job_title" required>

                    <label>Department</label>
                    <input type="text" name="department">

                    <label>Location</label>
                    <input type="text" name="location">

                    <label>Description</label>
                    <textarea name="description" rows="4"></textarea>

                    <label>Image</label>
                    <div class="img-row">
                        <div class="img-thumb">
                            <img id="new-preview" src="/images/placeholder.jpg" alt="">
                        </div>
                        <label class="img-placeholder">
                            <i class="fa fa-upload"></i>
                            <span>Choose Image</span>
                            <input type="file" name="image" accept="image/*" hidden
                                   onchange="previewImage(this, 'new-preview')">
                        </label>
                    </div>

                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
                        <button type="submit" class="btn-update">Create</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="footer-actions">
            <button class="btn-create" onclick="openModal()">Create New Job</button>
        </div>
    </main>

    <script>
        function previewImage(input, previewId) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById(previewId).src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function openModal() {
            document.getElementById('createModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('createModal').style.display = 'none';
        }

        function filterJobs() {
            const q = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('.job-card').forEach(card => {
                card.style.display = card.dataset.title.includes(q) ? '' : 'none';
            });
        }

        // Close modal on backdrop click
        document.getElementById('createModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
</body>
</html>